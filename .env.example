# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kemet_services

# Application
NODE_ENV=development
PORT=5000
APP_BASE_URL=http://localhost:5000

# Replit Auth (OIDC)
ISSUER_URL=https://replit.com/authn
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# Session
SESSION_SECRET=your_session_secret_here

# Gmail SMTP (for sending emails)
GMAIL_USER=infos@kemetservices.com
GMAIL_APP_PASSWORD=your_app_password_here

# PayDunya Wave Integration
PAYDUNYA_MASTER_KEY=your_master_key_here
PAYDUNYA_PRIVATE_KEY=your_private_key_here
PAYDUNYA_PUBLIC_KEY=your_public_key_here
PAYDUNYA_TOKEN=your_token_here
PAYDUNYA_MODE=test
WAVE_COUNTRY=SN
PAYDUNYA_WEBHOOK_SECRET=your_webhook_secret

# Anthropic Claude (génération automatique du quiz de certification à partir du PDF de cours)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Timezone
TZ=Africa/Abidjan
